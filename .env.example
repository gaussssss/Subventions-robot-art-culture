# ══ Sortie Google Sheets : choisir UNE des deux options ═════════════════════

# ── OPTION A (recommandée) : passerelle Apps Script, sans compte de service ──
# Un petit script est collé dans la feuille (Extensions → Apps Script, contenu
# de appscript/Code.gs) puis déployé en « application Web » — pas de console
# Google Cloud ni de clé JSON. Voir GUIDE.md, étape 3.
# URL du déploiement (se termine par /exec) :
APPSCRIPT_URL=
# La même phrase secrète que le JETON défini dans le script :
APPSCRIPT_TOKEN=

# ── OPTION B : compte de service Google Cloud (clé JSON) ─────────────────────
# ID de la feuille (la longue chaîne dans l'URL du Google Sheet)
# SHEET_ID=
# Chemin vers la clé JSON du compte de service (voir README, section Google Sheets).
# GOOGLE_SERVICE_ACCOUNT_FILE=compte-service.json
# Alternative : contenu de la clé, brut ou encodé en base64.
# GOOGLE_SERVICE_ACCOUNT_JSON=

# ══ Réglages facultatifs (valeurs par défaut raisonnables) ═══════════════════
# JOURS_RETENTION_EXPIRES=90
# DELAI_ENTRE_REQUETES_S=1.0
