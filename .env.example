# ── Google Sheets (obligatoire, sauf en mode --console) ─────────────────────
# ID de la feuille (la longue chaîne dans l'URL du Google Sheet)
SHEET_ID=
# Chemin vers la clé JSON du compte de service (voir README, section Google Sheets).
# Poser le fichier à la racine du projet sous ce nom :
GOOGLE_SERVICE_ACCOUNT_FILE=compte-service.json
# Alternative : contenu de la clé, brut ou encodé en base64.
# GOOGLE_SERVICE_ACCOUNT_JSON=

# ── Réglages facultatifs (valeurs par défaut raisonnables) ──────────────────
# JOURS_RETENTION_EXPIRES=90
# DELAI_ENTRE_REQUETES_S=1.0
